[Unit]
Description=Frame Display - Music Identification
After=network.target sound.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/frameDisplay
ExecStart=/home/pi/frameDisplay/venv/bin/python run.py
Restart=always
RestartSec=10
Environment=PYTHONUNBUFFERED=1
StandardOutput=journal
StandardError=journal
MemoryMax=512M

[Install]
WantedBy=multi-user.target
